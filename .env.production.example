# ─── DEPLOY CONFIG ──────────────────────────────────
# Configurações para deploy automatizado
# Copie este arquivo para .env.production e preencha os valores

# ─── VPS/Server Configuration ───────────────────────
VPS_USER=root
VPS_HOST=seu-servidor.com
VPS_PATH=/caminho/para/projeto
# Use chave SSH em vez de senha!
# VPS_PASS=  # NÃO USE - configure chave SSH

# ─── GitHub Configuration ───────────────────────────
GITHUB_TOKEN=seu-token-github-com-acesso-ao-repositorio
GITHUB_REPO=Wesll-Car02/crmproject.git
GITHUB_BRANCH=main

# ─── Database ──────────────────────────────────────
POSTGRES_USER=crmadmin
POSTGRES_PASSWORD=SUA_SENHA_FORTE_AQUI
POSTGRES_DB=crmdb

# ─── Redis ─────────────────────────────────────────
REDIS_PASSWORD=SUA_SENHA_REDIS_FORTE

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=SUPER_SECRET_JWT_KEY_MUDE_EM_PRODUCAO
JWT_REFRESH_SECRET=SUPER_REFRESH_SECRET_MUDE_EM_PRODUCAO

# ─── MinIO (S3 Storage) ────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=SUA_SENHA_MINIO_FORTE

# ─── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=SUA_CHAVE_OPENAI

# ─── WhatsApp (Evolution API) ──────────────────────
EVOLUTION_API_KEY=SUA_CHAVE_EVOLUTION_API

# ─── Email (SMTP) ──────────────────────────────────
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USER=seu-email@dominio.com
SMTP_PASS=SUA_SENHA_SMTP

# ─── Bradesco API (Financeiro) ─────────────────────
BRADESCO_CLIENT_ID=SEU_CLIENT_ID
BRADESCO_CLIENT_SECRET=SEU_CLIENT_SECRET
BRADESCO_AGENCY=SUA_AGENCIA
BRADESCO_ACCOUNT=SUA_CONTA

# ─── Meta (Facebook/Instagram/Ads) ────────────────
META_APP_ID=SEU_APP_ID
META_APP_SECRET=SEU_APP_SECRET
META_VERIFY_TOKEN=SEU_WEBHOOK_VERIFY_TOKEN

# ─── App Settings ──────────────────────────────────
APP_NAME=CRM Pro
APP_URL=https://seu-dominio.com
FRONTEND_URL=https://seu-dominio.com
NODE_ENV=production

# ─── Docker Settings ───────────────────────────────
DOCKER_COMPOSE_PROJECT_NAME=crmproj
DOCKER_NETWORK_NAME=crm_network

# ─── SSL/HTTPS ─────────────────────────────────────
# SSL_CERT_PATH=/etc/letsencrypt/live/seu-dominio.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/seu-dominio.com/privkey.pem

# ─── Backup Settings ───────────────────────────────
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Todos os dias às 2h
BACKUP_RETENTION_DAYS=30