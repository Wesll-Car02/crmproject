# ─── Database ──────────────────────────────────────
POSTGRES_USER=crmadmin
POSTGRES_PASSWORD=crmpassword123
POSTGRES_DB=crmdb

# ─── Redis ─────────────────────────────────────────
REDIS_PASSWORD=redispassword123

# ─── JWT ───────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-minimum-32-chars

# ─── MinIO (S3 Storage) ────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ─── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── WhatsApp (Evolution API) ──────────────────────
EVOLUTION_API_KEY=evolution-api-key-change-this

# ─── Email (SMTP) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Bradesco API (Financeiro) ─────────────────────
BRADESCO_CLIENT_ID=your-bradesco-client-id
BRADESCO_CLIENT_SECRET=your-bradesco-client-secret
BRADESCO_AGENCY=0000
BRADESCO_ACCOUNT=00000000

# ─── Meta (Facebook/Instagram/Ads) ────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-webhook-verify-token

# ─── Google Calendar OAuth ─────────────────────────
# Criar em: https://console.cloud.google.com/ > APIs > Google Calendar API
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Microsoft Calendar OAuth ───────────────────────
# Criar em: https://portal.azure.com/ > App registrations
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ─── App Settings ──────────────────────────────────
APP_NAME=MyCRM
APP_URL=http://localhost
FRONTEND_URL=http://localhost
